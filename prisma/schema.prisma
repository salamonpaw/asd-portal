generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  PARTNER
  PARTNER_ADMIN
  SERVICE_TECHNICIAN
  STAFF
  WAREHOUSE_SPECIALIST
  ADMIN
}

enum PartnerLevel {
  STANDARD
  BRONZE
  SILVER
  GOLD
  STRATEGIC
}

enum ProjectStatus {
  NEW
  VERIFY
  ACTIVE
  NOPROT
  NEEDINFO
  DUP
  REJECT
  EXPIRED
  DEACT
  WON
  LOST
}

enum Procurement {
  BIEZACA
  ZAPYTANIE
  PRZETARG
}


enum ServiceOrderStatus {
  NOWE
  PRZYJĘTE
  CZĘŚCIOWO_ZREALIZOWANE
  ZREALIZOWANE
  ODRZUCONE
  ZAWIESZONE
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  partnerId String?
  repId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner                    Partner?        @relation(fields: [partnerId], references: [id])
  rep                        Rep?            @relation(fields: [repId], references: [id])
  comments                   Comment[]
  serviceTechniciansOrders   ServiceOrder[]  @relation("ServiceTechnician")
  warehouseSpecialistOrders  ServiceOrder[]  @relation("WarehouseSpecialist")
}

// ─── Reps (Handlowcy ASD) ────────────────────────────────────────────────────

model Rep {
  id          String  @id @default(cuid())
  name        String
  initials    String
  email       String  @unique
  region      String
  phone       String?
  calendarUrl String?
  photoUrl    String?
  bio         String?

  users         User[]
  partners      Partner[]
  projects      Project[]
  ordersAsRep   Order[]  @relation("supervisorRep")
  ordersAsBok   Order[]  @relation("supervisorBok")
}

// ─── Partners ────────────────────────────────────────────────────────────────

model Partner {
  id               String       @id @default(cuid())
  name             String
  short            String
  city             String
  country          String
  level            PartnerLevel @default(BRONZE)
  discount         Int          @default(5)
  candidate        Boolean      @default(false)
  contact          String
  email            String
  phone            String
  since            String
  machinesReported Int          @default(0)
  repId            String
  createdAt        DateTime     @default(now())

  rep            Rep            @relation(fields: [repId], references: [id])
  users          User[]
  projects       Project[]
  markets        Market[]
  serviceOrders  ServiceOrder[]
  productDiscounts PartnerProductDiscount[]
}

model Market {
  id        String  @id @default(cuid())
  name      String
  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id              String        @id
  partnerId       String
  repId           String
  customerName    String
  customerTaxId   String
  customerCountry String
  location        String?
  branch          String?
  machines        String
  procurement     Procurement
  stage           String
  description     String
  decisionDate    String?
  interested      Boolean
  wantsSupport    Boolean
  support         String[]
  notes           String?
  discount        Int?
  status          ProjectStatus @default(VERIFY)
  protected       Boolean       @default(false)
  conflictsWith   String?
  createdAt       DateTime      @default(now())
  acceptedAt      DateTime?
  expiresAt       DateTime?
  updatedAt       DateTime      @updatedAt

  partner  Partner          @relation(fields: [partnerId], references: [id])
  rep      Rep              @relation(fields: [repId], references: [id])
  history  ProjectHistory[]
  comments Comment[]
  orders   Order[]

  @@index([customerTaxId])
}

model ProjectHistory {
  id        String   @id @default(cuid())
  projectId String
  date      DateTime @default(now())
  who       String
  text      String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  text      String
  internal  Boolean  @default(true)
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])
}

// ─── Orders ──────────────────────────────────────────────────────────────────

model Order {
  id                String        @id @default(cuid())
  code              String        @unique
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status            String        @default("pending")
  estimatedDays     Int?
  deliveryDate      DateTime?
  supervisorRepId   String?
  supervisorRep     Rep?          @relation("supervisorRep", fields: [supervisorRepId], references: [id])
  supervisorBokId   String?
  supervisorBok     Rep?          @relation("supervisorBok", fields: [supervisorBokId], references: [id])
  waitingFor        WaitingItem[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([projectId])
  @@index([code])
}

model WaitingItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type           String
  status         String   @default("pending")
  note           String?
  trackingNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([orderId])
}

// ─── Machine Types ────────────────────────────────────────────────────────────

model MachineType {
  id        String    @id @default(cuid())
  name      String    @unique
  label     String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// ─── Service Orders ───────────────────────────────────────────────────────────

model ServiceOrder {
  id                     String                @id @default(cuid())
  code                   String                @unique
  partnerId              String
  partner                Partner               @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  technicianId           String
  technician             User                  @relation("ServiceTechnician", fields: [technicianId], references: [id])
  items                  ServiceOrderItem[]
  status                 ServiceOrderStatus    @default(NOWE)
  deliveryAddress        String
  neededDate             DateTime?
  notes                  String?
  warehouseSpecialistId  String?
  warehouseSpecialist    User?                 @relation("WarehouseSpecialist", fields: [warehouseSpecialistId], references: [id])
  rejectionReason        String?
  trackingNumber         String?
  history                ServiceOrderHistory[]
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([partnerId])
  @@index([code])
}

model ServiceOrderItem {
  id                 String       @id @default(cuid())
  serviceOrderId     String
  serviceOrder       ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productId          String
  product            Product      @relation(fields: [productId], references: [id])
  quantity           Int
  fulfilledQuantity  Int?
  unitPrice          Decimal?     // Cena jednostkowa w momencie zamówienia
  discountType       String?      // "PERCENT" lub "AMOUNT"
  discountValue      Decimal?     // Wartość rabatu (% lub kwota)
  finalPrice         Decimal?     // Cena jednostkowa po rabacie
  createdAt          DateTime     @default(now())

  @@index([serviceOrderId])
  @@index([productId])
}

model Product {
  id               String      @id @default(cuid())
  sku              String      @unique
  name             String
  description      String?
  machineTypeId    String
  machineType      MachineType @relation(fields: [machineTypeId], references: [id], onDelete: Cascade)
  parentProductId  String?
  parentProduct    Product?    @relation("ProductHierarchy", fields: [parentProductId], references: [id])
  childProducts    Product[]   @relation("ProductHierarchy")
  location         String?
  image            String?
  images           String?       // JSON array of image URLs
  serialNumber     String?
  supplier         String?
  inStock          Int?
  costPrice        Decimal?      // Cena zakupu
  sellingPrice     Decimal?      // Cena sprzedaży dla klienta
  serviceOrderItems ServiceOrderItem[]
  partnerDiscounts PartnerProductDiscount[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([sku])
  @@index([machineTypeId])
}

model PartnerProductDiscount {
  id             String   @id @default(cuid())
  partnerId      String
  partner        Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  discountPercent Decimal  @default(0)  // Procentowy rabat dla tego partnera na ten produkt
  verifiedAt     DateTime? // Ostatnia weryfikacja rabatu
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([partnerId, productId])
  @@index([partnerId])
  @@index([productId])
}

model ServiceOrderHistory {
  id             String       @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  changedBy      String
  action         String
  notes          String?
  createdAt      DateTime     @default(now())

  @@index([serviceOrderId])
}

// ─── Content Management ───────────────────────────────────────────────────────

model ContentItem {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  label     String
  group     String
  updatedAt DateTime @updatedAt
}
